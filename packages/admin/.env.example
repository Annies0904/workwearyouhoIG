# Next.js admin UI environment variables
# Copy this file to .env.local and fill in your values

# Postgres (Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Instagram Page Access Token (for sending replies via Graph API)
INSTAGRAM_PAGE_ACCESS_TOKEN=your_page_access_token_here

# OpenAI API (for risk review in admin)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Next.js public URL (used for API calls)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
