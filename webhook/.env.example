# Node.js Webhook Server – Environment Variables
# Copy this file to .env and fill in the values

# --- Instagram / Meta ---
# Webhook verify token (you choose this; must match what you set in Meta Developer Console)
IG_VERIFY_TOKEN=your_webhook_verify_token_here

# Page Access Token from Meta Developer Console
IG_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Instagram Page ID
IG_PAGE_ID=your_instagram_page_id_here

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# Model to use for replies (gpt-4o recommended for quality)
OPENAI_MODEL=gpt-4o

# --- PostgreSQL ---
DATABASE_URL=postgresql://user:password@localhost:5432/ig_reply

# --- Server ---
PORT=3001

# Minimum confidence threshold; below this the message is flagged for human review
AI_CONFIDENCE_THRESHOLD=0.6
